{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/c/:id", "destination": "/c/index.html" }
  ],
  "headers": [
    {
      "source": "/docs/(.*)",
      "headers": [{ "key": "X-Robots-Tag", "value": "noindex" }]
    }
  ],
  "redirects": [
    { "source": "/docs", "destination": "/", "permanent": false },
    { "source": "/docs/(.*)", "destination": "/", "permanent": false }
  ]
}
